            },
            {
                "command": "gcmp.xiaomimimo.setTokenPlanApiKey",
                "title": "设置 Xiaomi MiMo Token Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.xiaomimimo.setTokenPlanEndpoint",
                "title": "设置 Xiaomi MiMo Token Plan 接入点",
                "category": "GCMP"
            },
            {
                "command": "gcmp.xiaomimimo.configWizard",
                "title": "启动 Xiaomi MiMo 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.baidu.setApiKey",
                "title": "设置 百度千帆 API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.baidu.setCodingPlanApiKey",
                "title": "设置 百度千帆 Coding Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.baidu.configWizard",
                "title": "启动 百度千帆 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.gemini.configWizard",
                "title": "Gemini CLI 配置向导（CLI 认证）",
                "category": "GCMP"
            },
            {
                "command": "gcmp.codex.configWizard",
                "title": "Codex CLI 配置向导（CLI 认证）",
                "category": "GCMP"
            },
            {
                "command": "gcmp.compatible.manageModels",
                "title": "Compatible Provider 设置",
                "category": "GCMP"
            },
            {
                "command": "gcmp.nesCompletion.toggleManual",
                "title": "切换 NES 手动触发模式",
                "category": "GCMP"
            },
            {
                "command": "gcmp.tokenUsage.showDetails",
                "title": "查看今日 Token 消耗统计详情",

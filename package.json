    "scripts": {
        "vscode:prepublish": "npm run clean && npm run compile",
        "compile": "node esbuild.config.js",
        "compile:dev": "node esbuild.config.js --dev",
        "clean": "rimraf dist",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{ts,js,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
        "watch": "node esbuild.config.js --watch --dev",
        "package": "vsce package",
        "publish": "vsce publish --allow-proposed-apis chatProvider",
        "pretest": "npm run compile:dev",
        "test": "npm run test:schema-sanitizer && npm run test:stateful-marker && npm run test:reasoning-replay && npm run test:request-message-filter",
        "test:reasoning-replay": "tsx --test src/handlers/reasoningReplayPolicy.test.ts",
        "test:request-message-filter": "tsx --test src/utils/requestMessageFilter.test.ts",
        "test:schema-sanitizer": "tsx --test src/utils/schemaSanitizer.test.ts",
        "test:stateful-marker": "tsx --test src/handlers/statefulMarkerCodec.test.ts"
    },

{
    "name": "gcmp",
    "publisher": "vicanent",
    "displayName": "AI Chat Models",
    "description": "为 GitHub Copilot Chat 提供 智谱AI、MiniMax、MoonshotAI、DeepSeek、阿里云百炼、快手万擎、火山方舟、腾讯云、Xiaomi MiMo、百度千帆 模型支持的扩展，并提供 `OpenAI / Anthropic Compatible` 自定义模型支持。",
    "version": "0.22.10",
    "license": "MIT",
    "keywords": [
        "ai",
        "chat",
        "copilot",
        "github-copilot",
        "language-model",
        "zhipu",
        "kimi",
        "volcengine",
        "minimax",
        "moonshot",
        "deepseek",
        "streamlake",
        "dashscope",
        "tencent",
        "Xiaomi MiMo",
        "baidu",
        "qianfan",
        "百度千帆",
        "OpenAI Compatible",
        "Anthropic Compatible",
        "智谱AI",
        "火山方舟",
        "月之暗面",
        "深度求索",
        "快手万擎",
        "阿里云百炼",
        "腾讯云",
        "百度千帆",
        "Coding Plan 编程套餐"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/VicBilibily/GCMP.git"
    },
    "engines": {
        "vscode": ">=1.116.0",
        "node": ">=20.0.0",
        "npm": ">=9.0.0"
    },
    "extensionDependencies": [
        "github.copilot-chat"
    ],
    "categories": [
        "AI",
        "Chat"
    ],
    "icon": "./gcmp-logo.png",
    "main": "./dist/extension.js",
    "enabledApiProposals": [
        "chatProvider"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguageModelProvider:gcmp.zhipu",
        "onLanguageModelProvider:gcmp.minimax",
        "onLanguageModelProvider:gcmp.moonshot",
        "onLanguageModelProvider:gcmp.deepseek",
        "onLanguageModelProvider:gcmp.dashscope",
        "onLanguageModelProvider:gcmp.streamlake",
        "onLanguageModelProvider:gcmp.volcengine",
        "onLanguageModelProvider:gcmp.tencent",
        "onLanguageModelProvider:gcmp.xiaomimimo",
        "onLanguageModelProvider:gcmp.gemini",
        "onLanguageModelProvider:gcmp.codex",
        "onLanguageModelProvider:gcmp.baidu",
        "onLanguageModelProvider:gcmp.compatible",
        "onLanguageModelTool:gcmp_zhipuWebSearch",
        "onLanguageModelTool:gcmp_minimaxWebSearch",
        "onLanguageModelTool:gcmp_kimiWebSearch",
        "onLanguageModelTool:gcmp_dashscopeWebSearch",
        "onFileSystem:gcmp-settings"
    ],
    "contributes": {
        "commands": [
            {
                "command": "gcmp.zhipu.setApiKey",
                "title": "设置 智谱AI API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.zhipu.configWizard",
                "title": "智谱AI 配置向导（API密钥 & 搜索 MCP 模式）",
                "category": "GCMP"
            },
            {
                "command": "gcmp.minimax.setApiKey",
                "title": "设置 MiniMax API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.minimax.setCodingPlanApiKey",
                "title": "设置 MiniMax Coding Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.minimax.setCodingPlanEndpoint",
                "title": "设置 MiniMax Coding Plan 接入点（国内/国际站）",
                "category": "GCMP"
            },
            {
                "command": "gcmp.minimax.configWizard",
                "title": "启动 MiniMax 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.kimi.setApiKey",
                "title": "设置 Kimi API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.moonshot.setApiKey",
                "title": "设置 MoonshotAI API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.moonshot.configWizard",
                "title": "启动 MoonshotAI 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.deepseek.setApiKey",
                "title": "设置 DeepSeek API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.volcengine.setApiKey",
                "title": "设置 火山方舟 API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.volcengine.setAgentPlanApiKey",
                "title": "设置 火山方舟 Agent Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.volcengine.configWizard",
                "title": "火山方舟 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.streamlake.setApiKey",
                "title": "设置 快手万擎 API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.dashscope.setApiKey",
                "title": "设置 阿里云百炼 API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.dashscope.setCodingPlanApiKey",
                "title": "设置 阿里云百炼 Coding Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.dashscope.setTokenPlanApiKey",
                "title": "设置 阿里云百炼 Token Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.dashscope.configWizard",
                "title": "启动 阿里云百炼 配置向导",
                "category": "GCMP"
            },
            {
                "command": "gcmp.tencent.setApiKey",
                "title": "设置 腾讯云大模型 API密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.tencent.setCodingPlanApiKey",
                "title": "设置 腾讯云 Coding Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.tencent.setTokenPlanApiKey",
                "title": "设置 腾讯云 Token Plan 专用密钥",
                "category": "GCMP"
            },
            {
                "command": "gcmp.tencent.setDeepSeekApiKey",

            {
                "name": "gcmp_zhipuWebSearch",
                "displayName": "智谱AI联网搜索",
                "toolReferenceName": "zhipuWebSearch",
                "modelDescription": "使用智谱AI提供的联网搜索功能获取实时信息。支持多种搜索引擎：search_std（标准搜索，¥0.01）、search_pro（高级搜索，¥0.03）、search_pro_sogou（搜狗搜索，¥0.05）、search_pro_quark（夸克搜索，¥0.05）。注意：Pro+ 套餐可通过 MCP SSE 调用，非订阅套餐使用标准计费接口。",
                "userDescription": "通过智谱AI联网搜索获取最新信息",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "search_query": {
                            "type": "string",
                            "description": "搜索查询字符串"
                        },
                        "search_engine": {
                            "type": "string",
                            "enum": [
                                "search_std",
                                "search_pro",
                                "search_pro_sogou",
                                "search_pro_quark"
                            ],
                            "description": "搜索引擎类型：search_std（标准，¥0.01）、search_pro（高级，¥0.03）、search_pro_sogou（搜狗，¥0.05）、search_pro_quark（夸克，¥0.05）",
                            "default": "search_std"
                        },
                        "search_intent": {
                            "type": "boolean",
                            "description": "是否进行搜索意图分析",
                            "default": false
                        },
                        "count": {
                            "type": "integer",
                            "description": "返回搜索结果数量",
                            "minimum": 1,
                            "maximum": 20,
                            "default": 10
                        },
                        "search_domain_filter": {
                            "type": "string",
                            "description": "域名过滤器，限制搜索特定网站"
                        },
                        "search_recency_filter": {
                            "type": "string",
                            "enum": [
                                "noLimit",
                                "day",
                                "week",
                                "month",
                                "year"
                            ],
                            "description": "时间过滤器：noLimit（无限制）、day（一天内）、week（一周内）、month（一月内）、year（一年内）",
                            "default": "noLimit"
                        },
                        "content_size": {
                            "type": "string",
                            "enum": [
                                "low",
                                "medium",
                                "high"
                            ],
                            "description": "内容详细程度：low（低）、medium（中）、high（高）",
                            "default": "medium"
                        }

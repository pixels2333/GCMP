                "icon": "$(gcmp-git-commit)"
            },
            {
                "command": "gcmp.commit.generateMessageWorkingTree",
                "title": "生成提交消息 - 未暂存的更改",
                "category": "GCMP",
                "icon": "$(gcmp-git-commit)"
            },
            {
                "command": "gcmp.commit.selectModel",
                "title": "选择 Commit 消息生成模型",
                "category": "GCMP"
            }
        ],
        "configuration": {
            "title": "GCMP - AI Chat Models",
            "properties": {
                "gcmp.maxTokens": {
                    "type": "number",
                    "default": 16000,
                    "minimum": 32,
                    "maximum": 256000,
                    "description": "控制AI模型输出的最大token数量。较大的值允许更长的响应。",
                    "scope": "application"
                },
                "gcmp.retry.maxAttempts": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 5,
                    "description": "请求失败后的最大自动重试次数，仅对可重试错误生效。重试延迟按 1s、3s、6s、10s、15s 的累加序列递增。",
                    "scope": "application"
                },
                "gcmp.temperature": {
                    "type": "number",
                    "deprecationMessage": "temperature 已被弃用，请改用模型的 extraBody 参数传递",
                    "description": "模型采样温度（已弃用）",
                    "scope": "application"
                },
                "gcmp.topP": {
                    "type": "number",
                    "deprecationMessage": "topP 已被弃用，请改用模型的 extraBody 参数传递",
                    "description": "模型采样 top-p 参数（已弃用）",
                    "scope": "application"
                },
                "gcmp.rememberLastModel": {
                    "type": "boolean",
                    "deprecationMessage": "rememberLastModel 已被弃用，此功能不再被支持",
                    "description": "是否记住上次选择的模型（已弃用）",
                    "scope": "application"
                },
                "gcmp.editToolMode": {
                    "type": "string",
                    "enum": [
                        "claude",
                        "gpt-5",
                        "none"
                    ],
                    "enumDescriptions": [
                        "使用 Claude 风格的编辑工具 (ReplaceString) - 高效精确的单次替换",
                        "使用 GPT-5 风格的编辑工具 (ApplyPatch) - 批量差异应用，支持复杂重构",
                        "不使用特定优化工具，直接文件编辑 - 效率较低，适合处理编辑异常情况"
                    ],
                    "default": "claude",
                    "deprecationMessage": "editToolMode 已被弃用，请在模型配置中使用 family 字段代替。此配置将在未来版本中移除。",
                    "description": "选择编辑工具模式。Claude 使用高效的ReplaceString，GPT-5 使用ApplyPatch进行批量编辑，None 直接使用基础文件编辑。",
                    "scope": "application"
                },
                "gcmp.autoPrefixModelId": {
                    "type": "boolean",
                    "default": false,
                    "description": "在模型列表中为模型ID自动添加提供商前缀（例如：zhipu:::glm-5）。启用此选项可缓解 VS Code 模型选择器显示模型不全的问题。",
                    "scope": "application"
                },
                "gcmp.zhipu.search.enableMCP": {
                    "type": "boolean",
                    "default": true,
                    "description": "启用智谱AI搜索的MCP SDK模式。使用标准 MCP 协议和官方 SDK 实现搜索功能，提供更稳定的连接和更好的错误处理。非订阅套餐请关闭此开关以使用标准计费接口（按次计费）。需要有效的智谱AI API密钥。",
                    "scope": "application"
                },
                "gcmp.zhipu.endpoint": {
                    "type": "string",
                    "enum": [
                        "open.bigmodel.cn",
                        "api.z.ai"
                    ],
                    "default": "open.bigmodel.cn",
                    "description": "智谱AI接入站点。open.bigmodel.cn 为国内站（推荐），api.z.ai 为国际站。",
                    "scope": "application"
                },
                "gcmp.minimax.endpoint": {
                    "type": "string",
                    "enum": [
                        "minimaxi.com",
                        "minimax.io"
                    ],
                    "default": "minimaxi.com",
                    "description": "MiniMax Coding Plan 接入站点。minimaxi.com 为国内站（推荐），minimax.io 为国际站。",
                    "scope": "application"
                },
                "gcmp.xiaomimimo.endpoint": {
                    "type": "string",
                    "enum": [
                        "cn",
                        "sgp",
                        "ams"
                    ],
                    "default": "cn",
                    "description": "Xiaomi MiMo Token Plan 接入点。cn 为中国接入点（默认），sgp 为新加坡接入点，ams 为欧洲接入点。",
                    "scope": "application"
                },
                "gcmp.usages.retentionDays": {
                    "type": "number",
                    "default": 100,
                    "minimum": 0,
                    "maximum": 365,
                    "description": "Token消耗记录历史数据保留天数（按日期保存，0表示永久保留）。",
                    "scope": "application"
                },
                "gcmp.fimCompletion.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "启用 FIM (Fill In the Middle) 建议功能。",
                    "scope": "application"
                },
                "gcmp.fimCompletion.debounceMs": {
                    "type": "number",
                    "default": 500,
                    "minimum": 50,
                    "maximum": 1000,
                    "description": "FIM 补全的防抖延迟（毫秒）。",
                    "scope": "application"
                },
                "gcmp.fimCompletion.timeoutMs": {
                    "type": "number",
                    "default": 5000,
                    "minimum": 1000,
                    "maximum": 30000,
                    "description": "FIM 补全的请求超时时间（毫秒）。",
                    "scope": "application"
                },
                "gcmp.fimCompletion.modelConfig": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "baseUrl": "",
                        "model": ""
                    },
                    "description": "FIM 补全使用的模型配置。",
                    "scope": "application",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "模型提供商标识符"
                        },
                        "baseUrl": {
                            "type": "string",
                            "description": "API基础URL",
                            "format": "uri"
                        },
                        "model": {
                            "type": "string",
                            "description": "FIM 补全使用的模型名称"
                        },
                        "maxTokens": {
                            "type": "number",
                            "description": "FIM 补全返回的最大长度",
                            "default": 200,
                            "minimum": 50,
                            "maximum": 16000
                        },
                        "extraBody": {
                            "type": "object",
                            "description": "额外的请求体参数，将在API请求中合并到请求体中",
                            "additionalProperties": {
                                "description": "额外的请求体参数值"
                            }
                        }
                    },
                    "required": [
                        "provider",
                        "baseUrl",
                        "model"
                    ]
                },
                "gcmp.nesCompletion.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "启用 NES (Next Edit Suggestions) 建议功能。",
                    "scope": "application"
                },
                "gcmp.nesCompletion.debounceMs": {
                    "type": "number",
                    "default": 500,
                    "minimum": 50,
                    "maximum": 1000,
                    "description": "NES 补全的防抖延迟（毫秒）。",
                    "scope": "application"
                },
                "gcmp.nesCompletion.timeoutMs": {
                    "type": "number",
                    "default": 5000,
                    "minimum": 1000,
                    "maximum": 30000,
                    "description": "NES 补全的请求超时时间（毫秒）。",
                    "scope": "application"
                },
                "gcmp.nesCompletion.manualOnly": {
                    "type": "boolean",
                    "default": false,
                    "description": "启用后，NES 补全仅响应手动触发（Alt+/），不会自动触发。",
                    "scope": "application"
                },
                "gcmp.nesCompletion.modelConfig": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "baseUrl": "",
                        "model": ""
                    },
                    "description": "NES 补全使用的模型配置。",
                    "scope": "application",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "模型提供商标识符"
                        },
                        "baseUrl": {
                            "type": "string",
                            "description": "API基础URL",
                            "format": "uri"
                        },
                        "model": {
                            "type": "string",
                            "description": "NES 补全使用的模型名称"
                        },
                        "maxTokens": {
                            "type": "number",
                            "description": "NES 补全返回的最大长度",
                            "default": 200,
                            "minimum": 50,
                            "maximum": 16000
                        },
                        "extraBody": {
                            "type": "object",
                            "description": "额外的请求体参数，将在API请求中合并到请求体中",
                            "additionalProperties": {
                                "description": "额外的请求体参数值"
                            }
                        }
                    },
                    "required": [
                        "provider",
                        "baseUrl",
                        "model"
                    ]
                },
                "gcmp.commit.language": {
                    "type": "string",
                    "enum": [
                        "chinese",
                        "english"
                    ],
                    "enumDescriptions": [
                        "Chinese - 默认/回退语言（auto 模式下历史语言不明确时使用中文）",
                        "English - Default/fallback language (used when auto mode language is unclear)"
                    ],
                    "default": "chinese",
                    "description": "生成提交消息使用的语言。auto 模式会优先从仓库最近提交历史推断语言；当历史语言不明确时回退为此配置。支持在工作区和全局配置中设置，工作区配置优先级更高。",
                    "scope": "window"
                },
                "gcmp.commit.format": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "plain",
                        "custom",
                        "conventional",
                        "angular",
                        "karma",
                        "semantic",
                        "emoji",
                        "emojiKarma",
                        "google",
                        "atom"
                    ],
                    "enumDescriptions": [
                        "Auto - 根据历史提交记录推断提交规范；无法推断则回退为 Plain",
                        "Plain - 简洁的一句话提交描述（示例：修复配置回退逻辑）",
                        "Custom - 使用自定义指令生成提交消息（示例：PROJ-123: 修复登录跳转）",
                        "Conventional Commits - 约定式提交格式（示例：feat(auth): 添加登录）",
                        "Angular - Angular 项目风格（示例：fix(core): 处理空配置）",
                        "Karma - Karma 测试框架风格（示例：feat(ui): 增加提交向导）",
                        "Semantic - 语义化版本风格（示例：fix: 修复无效格式回退）",
                        "Emoji - 表情符号风格（示例：🐛 修复配置回退）",
                        "EmojiKarma - 表情符号 + Karma 风格（示例：✨ feat(auth): 添加登录）",
                        "Google - Google 项目风格（示例：Fix: 修复无效格式回退）",
                        "Atom - Atom 编辑器风格（示例：:bug: 修复配置回退）"
                    ],
                    "default": "auto",
                    "description": "生成提交消息使用的格式。auto 会根据历史提交记录推断提交规范；无法推断则回退为 plain。支持在工作区和全局配置中设置，工作区配置优先级更高。",
                    "scope": "window"
                },
                "gcmp.commit.customInstructions": {
                    "type": "string",
                    "default": "",
                    "description": "自定义的提交消息生成指令（当 commitFormat=custom 时生效）。",
                    "scope": "window"
                },
                "gcmp.commit.model": {
                    "type": "object",
                    "default": {
                        "provider": "",
                        "model": ""
                    },
                    "description": "指定用于生成提交消息的模型（provider + model）。留空则会提示选择模型。",
                    "scope": "window",
                    "properties": {
                        "provider": {
                            "type": "string",
                            "description": "语言模型提供商（providerKey），例如 zhipu / compatible"
                        },
                        "model": {
                            "type": "string",
                            "description": "模型 ID（对应 Language Model API 的 model.id）"
                        }
                    },
                    "required": [
                        "provider",
                        "model"
                    ]
                },
                "gcmp.providerOverrides": {
                    "type": "object",
                    "default": {},
                    "description": "提供商配置覆盖。允许覆盖提供商的baseUrl和模型配置，支持添加新模型或覆盖现有模型的参数。",
                    "scope": "application"
                },
                "gcmp.compatibleModels": {
                    "type": "array",
                    "default": [],
                    "description": "Compatible Provider 的自定义模型配置。完全由用户配置的 OpenAI / Anthropic 兼容模型列表。",
                    "scope": "application"
                }
            }
        },
        "jsonValidation": [
            {
                "fileMatch": "settings.json",
                "url": "gcmp-settings://root/schema.json"
            }
        ],
        "languageModelChatProviders": [
            {
                "vendor": "gcmp.zhipu",
                "displayName": "GCMP · ZhipuAI",
                "managementCommand": "gcmp.zhipu.configWizard"
            },
            {
                "vendor": "gcmp.minimax",
                "displayName": "GCMP · MiniMax",
